<div class="overflow-x-auto">
  <table class="min-w-full">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Article</th>
        <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Quantité</th>
        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Prix unitaire HT</th>
        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Total HT</th>
        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">TVA</th>
        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">TVA montant</th>
        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Total TTC</th>
        <% if quote.draft? %>
          <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% quote.items.each do |item| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= item.name %></td>
          <td class="px-6 py-4 text-sm text-center text-gray-700"><%= item.quantity %></td>
          <td class="px-6 py-4 text-sm text-right text-gray-700"><%= number_to_currency(item.unit_price, unit: '€') %></td>
          <td class="px-6 py-4 text-sm text-right text-gray-700"><%= number_to_currency(item.total_ht, unit: '€') %></td>
          <td class="px-6 py-4 text-sm text-right text-gray-700"><%= number_to_percentage(item.vat_rate, precision: 2) %></td>
          <td class="px-6 py-4 text-sm text-right text-gray-700"><%= number_to_currency(item.total_vat, unit: '€') %></td>
          <td class="px-6 py-4 text-sm text-right font-semibold text-gray-900"><%= number_to_currency(item.total_ttc, unit: '€') %></td>
          <% if quote.draft? %>
            <td class="px-6 py-4 text-sm text-right">
              <div class="flex justify-end gap-2">
                <%= link_to edit_quote_item_path(quote, item), class: 'inline-flex items-center justify-center w-8 h-8 rounded text-blue-600 hover:bg-blue-50 transition', title: 'Edit' do %>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg>
                <% end %>
                <%= button_to quote_item_path(quote, item), method: :delete, data: { confirm: 'Êtes-vous sûr ?' }, class: 'inline-flex items-center justify-center w-8 h-8 rounded text-red-600 hover:bg-red-50 transition', title: 'Delete' do %>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
