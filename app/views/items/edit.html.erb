<div class="min-h-screen bg-gray-100 py-12">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6">
      <%= link_to '← Retour', @quote, class: 'text-gray-600 hover:text-gray-900 text-sm font-medium' %>
    </div>

    <div class="bg-white shadow-sm rounded-lg p-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">Modifier l'article</h1>

      <% if @item.errors.any? %>
        <div class="mb-6 p-4 bg-red-50 rounded-lg border border-red-200">
          <h2 class="text-sm font-semibold text-red-900 mb-2"><%= pluralize(@item.errors.count, "erreur") %> :</h2>
          <ul class="list-disc list-inside text-sm text-red-700">
            <% @item.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: [@quote, @item], local: true, class: 'space-y-6') do |form| %>
        <div>
          <%= form.label :name, 'Nom de l\'article', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
          <%= form.text_field :name, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
        </div>

        <div>
          <%= form.label :quantity, 'Quantité', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
          <%= form.number_field :quantity, min: 1, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
        </div>

        <div>
          <%= form.label :unit_price, 'Prix unitaire HT (€)', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
          <%= form.number_field :unit_price, step: 0.01, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
        </div>

        <div>
          <%= form.label :vat_rate, 'Taux TVA (%)', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
          <%= form.number_field :vat_rate, step: 0.01, min: 0, max: 100, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
        </div>

        <div class="flex gap-4 pt-4">
          <%= form.submit 'Mettre à jour', class: 'px-6 py-2 bg-blue-600 text-white font-semibold rounded hover:bg-blue-700 transition' %>
          <%= link_to 'Annuler', @quote, class: 'px-6 py-2 bg-gray-300 text-gray-900 font-semibold rounded hover:bg-gray-400 transition' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
