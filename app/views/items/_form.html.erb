<div id="new-item-form" class="new-item-form" style="display: none;">
  <h4 style="margin: 0 0 16px; font-size: 12px; font-weight: 700; color: #211747;">Nouvel article</h4>
  
  <%= form_with(model: [@quote, Item.new], local: true) do |form| %>
    <div class="form-grid">
      <div class="form-group">
        <%= form.label :name, 'Nom' %>
        <%= form.text_field :name, placeholder: 'Nom de l\'article' %>
      </div>
      <div class="form-group">
        <%= form.label :quantity, 'Quantité' %>
        <%= form.number_field :quantity, value: 1, min: 1 %>
      </div>
    </div>

    <div class="form-grid">
      <div class="form-group">
        <%= form.label :unit_price, 'Prix unitaire HT (€)' %>
        <%= form.number_field :unit_price, step: 0.01, min: 0, placeholder: '100.00' %>
      </div>
      <div class="form-group">
        <%= form.label :vat_rate, 'Taux TVA (%)' %>
        <%= form.number_field :vat_rate, value: 20, step: 0.01, min: 0, max: 100 %>
      </div>
    </div>

    <div class="form-actions">
      <%= form.submit 'Ajouter', class: 'primary' %>
      <button type="button" class="cancel-btn" data-action="click->quote-form#toggleNewItemForm">Annuler</button>
    </div>
  <% end %>
</div>

<style>
  .new-item-form {
    display: none;
  }
  .new-item-form.show {
    display: block;
  }
  .cancel-btn {
    background: #ffffff;
    border: 1.5px solid #d8d1ec;
    color: #211747;
    border-radius: 4px;
    padding: 8px 20px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
  }
  .cancel-btn:hover {
    background: #f4f4f4;
  }
</style>
