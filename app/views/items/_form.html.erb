<div id="new-item-form" class="mb-8 p-6 bg-blue-50 rounded-lg border border-blue-200 hidden">
  <h3 class="text-lg font-bold text-gray-900 mb-6">Nouvel article</h3>
  <%= form_with(model: [@quote, Item.new], local: true, class: 'space-y-4') do |form| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :name, 'Nom de l\'article', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
        <%= form.text_field :name, placeholder: 'Ex: Salle de conférence', class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
      </div>
      <div>
        <%= form.label :quantity, 'Quantité', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
        <%= form.number_field :quantity, value: 1, min: 1, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :unit_price, 'Prix unitaire HT (€)', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
        <%= form.number_field :unit_price, step: 0.01, min: 0, placeholder: '100.00', class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
      </div>
      <div>
        <%= form.label :vat_rate, 'Taux TVA (%)', class: 'block text-sm font-semibold text-gray-900 mb-2' %>
        <%= form.number_field :vat_rate, value: 20, step: 0.01, min: 0, max: 100, class: 'w-full px-4 py-2 border border-gray-300 rounded hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-0' %>
      </div>
    </div>
    <div class="flex gap-3 pt-4">
      <%= form.submit 'Ajouter l\'article', class: 'px-4 py-2 bg-green-600 text-white font-semibold rounded hover:bg-green-700 transition' %>
      <button type="button" class="px-4 py-2 bg-gray-400 text-white font-semibold rounded hover:bg-gray-500 transition" data-action="click->quote-form#toggleNewItemForm">Annuler</button>
    </div>
  <% end %>
</div>
