<div id="new-item-form" class="item-form" hidden>
  <h3>Nouvel item</h3>
  <%= form_with(model: [quote, Item.new], local: true) do |form| %>
    <div class="form-grid">
      <div class="form-field">
        <%= form.label :name, 'Nom' %>
        <%= form.text_field :name, placeholder: 'Ex: Location salle Atrium' %>
      </div>
      <div class="form-field">
        <%= form.label :quantity, 'Quantité' %>
        <%= form.number_field :quantity, value: 1, min: 1 %>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-field">
        <%= form.label :unit_price, 'Prix unitaire HT (€)' %>
        <%= form.number_field :unit_price, step: 0.01, min: 0, placeholder: '50.99' %>
      </div>
      <div class="form-field">
        <%= form.label :vat_rate, 'TVA (%)' %>
        <%= form.number_field :vat_rate, value: 20, step: 0.01, min: 0, max: 100 %>
      </div>
    </div>
    <div class="form-actions">
      <%= form.submit 'Ajouter', class: 'btn btn--primary' %>
      <button type="button" class="btn" data-action="click->quote-form#toggleNewItemForm">Annuler</button>
    </div>
  <% end %>
</div>
