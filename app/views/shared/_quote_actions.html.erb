<div class="flex gap-2">
  <% if quote.draft? %>
    <%= link_to edit_quote_path(quote), class: 'px-3 py-2 bg-blue-600 text-white text-sm font-semibold rounded hover:bg-blue-700 transition flex items-center gap-2', title: 'Edit' do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg>
      Modifier
    <% end %>
    
    <%= button_to quote_path(quote), method: :patch, params: { quote: { status: 'validated' } }, data: { confirm: 'Êtes-vous sûr de vouloir valider ce devis ?' }, class: 'px-3 py-2 bg-green-600 text-white text-sm font-semibold rounded hover:bg-green-700 transition flex items-center gap-2', title: 'Validate' do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
      Valider
    <% end %>
    
    <%= button_to quote_path(quote), method: :delete, data: { confirm: 'Êtes-vous sûr ?' }, class: 'px-3 py-2 bg-red-600 text-white text-sm font-semibold rounded hover:bg-red-700 transition flex items-center gap-2', title: 'Delete' do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
      Supprimer
    <% end %>
  <% else %>
    <span class="px-3 py-2 text-gray-500 text-sm font-semibold">Devis validé</span>
  <% end %>
</div>
