<div class="btn-group">
  <% if quote.draft? %>
    <%= link_to 'Éditer', edit_quote_path(quote), class: 'btn' %>
    <%= button_to 'Valider',
                  quote_path(quote),
                  method: :patch,
                  params: { quote: { status: 'validated' } },
                  form: { data: { turbo_confirm: 'Valider ce devis ? Il ne sera plus modifiable.' } },
                  class: 'btn btn--success' %>
    <%= button_to 'Supprimer',
                  quote_path(quote),
                  method: :delete,
                  form: { data: { turbo_confirm: 'Supprimer ce devis ?' } },
                  class: 'btn btn--danger' %>
  <% end %>
</div>
