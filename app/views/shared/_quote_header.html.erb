<div class="px-8 py-6 border-b border-gray-200">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= quote.name %></h1>
      <span class="px-3 py-1 rounded-full text-sm font-semibold <%= quote.draft? ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800' %>">
        <%= quote.status.humanize %>
      </span>
    </div>
    <%= render 'shared/quote_actions', quote: quote %>
  </div>
</div>
