<div class="page" data-controller="quote-form">
  <span class="tag">Devis</span>

  <%= link_to '< Retour aux devis', quotes_path, class: 'breadcrumb' %>

  <% if flash[:notice] %>
    <div class="flash flash--notice"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="flash flash--alert"><%= flash[:alert] %></div>
  <% end %>

  <%= render 'shared/quote_header', quote: @quote %>

  <div class="section">
    <div class="section-title">
      <span>Items</span>
      <% if @quote.draft? %>
        <button type="button" class="btn" data-action="click->quote-form#toggleNewItemForm">
          <span class="plus">+</span> Ajouter un item
        </button>
      <% end %>
    </div>

    <% if @quote.draft? %>
      <%= render 'items/form', quote: @quote %>
    <% end %>

    <% if @quote.items.any? %>
      <%= render 'items/list', quote: @quote %>
    <% else %>
      <div class="empty-state">Aucun item dans ce devis.</div>
    <% end %>
  </div>

  <div class="totals">
    <%= render 'shared/total_card', label: 'Total HT', value: number_to_currency(@quote.total_ht, unit: '€', format: '%n %u'), highlight: false %>
    <%= render 'shared/total_card', label: 'Total TVA', value: number_to_currency(@quote.total_vat, unit: '€', format: '%n %u'), highlight: false %>
    <%= render 'shared/total_card', label: 'Total TTC', value: number_to_currency(@quote.total_ttc, unit: '€', format: '%n %u'), highlight: true %>
  </div>
</div>
