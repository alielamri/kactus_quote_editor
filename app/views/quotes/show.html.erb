<div class="min-h-screen bg-gray-50" data-controller="quote-form">
  <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8">
    <div class="mb-8">
      <%= link_to 'Back to Quotes', quotes_path, class: 'text-blue-600 hover:text-blue-800 font-semibold' %>
    </div>

    <div class="bg-white shadow rounded-lg overflow-hidden">
      <%= render 'shared/quote_header', quote: @quote %>

      <!-- Items Section -->
      <div class="px-8 py-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900">Items</h2>
          <% if @quote.draft? %>
            <button type="button" class="px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition" data-action="click->quote-form#toggleNewItemForm">Add Item</button>
          <% end %>
        </div>

        <!-- New Item Form -->
        <% if @quote.draft? %>
          <%= render 'items/form', quote: @quote %>
        <% end %>

        <!-- Items Table -->
        <% if @quote.items.any? %>
          <%= render 'items/list', quote: @quote %>
        <% else %>
          <div class="text-center py-12">
            <p class="text-gray-500 text-lg">No items yet</p>
          </div>
        <% end %>
      </div>

      <!-- Totals Section -->
      <div class="px-8 py-6 bg-gray-50 border-t border-gray-200">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <%= render 'shared/total_card', label: 'Total HT (ex. VAT)', value: number_to_currency(@quote.total_ht, unit: '€'), color: 'text-gray-900', highlight: false %>
          <%= render 'shared/total_card', label: 'Total VAT', value: number_to_currency(@quote.total_vat, unit: '€'), color: 'text-blue-600', highlight: false %>
          <%= render 'shared/total_card', label: 'Total TTC (inc. VAT)', value: number_to_currency(@quote.total_ttc, unit: '€'), color: 'text-green-600', highlight: true %>
        </div>
      </div>
    </div>
  </div>
</div>
