<div class="page page--narrow">
  <span class="tag">Édition du devis</span>

  <%= link_to '< Retour au devis', @quote, class: 'breadcrumb' %>
  <h1 class="page-title">Modifier le devis</h1>

  <% if @quote.errors.any? %>
    <div class="error-box">
      <h2><%= pluralize(@quote.errors.count, 'erreur') %></h2>
      <ul>
        <% @quote.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @quote, local: true) do |form| %>
    <div class="form-field" style="margin-bottom: 18px;">
      <%= form.label :name, 'Nom' %>
      <%= form.text_field :name, autofocus: true %>
    </div>

    <div class="form-actions">
      <%= form.submit 'Enregistrer', class: 'btn btn--primary' %>
      <%= link_to 'Annuler', @quote, class: 'btn' %>
    </div>
  <% end %>
</div>
