<div class="screen-wrapper">
  <div class="screen-inner">
    <div class="screen-label">Liste des devis</div>

    <section class="page">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Mes devis</h1>
        <%= link_to new_quote_path, class: 'add-btn', style: 'margin: 0; text-decoration: none;' do %>
          <span class="plus">＋</span>
          Ajouter un devis
        <% end %>
      </div>

      <% if @quotes.any? %>
        <div style="overflow-x: auto;">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Nom</th>
                <th></th>
              </tr>
            </thead>

            <tbody>
              <% @quotes.each_with_index do |quote, index| %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%= quote.created_at.strftime('%d/%m/%Y') %></td>
                  <td>
                    <%= link_to quote.name, quote_path(quote), style: 'color: #211747; text-decoration: none;' %>
                  </td>
                  <td class="actions">
                    <% if quote.draft? %>
                      <%= link_to '✎', edit_quote_path(quote), class: 'icon-btn', style: 'text-decoration: none;' %>
                      <%= button_to '🗑', quote_path(quote), method: :delete, data: { confirm: 'Êtes-vous sûr ?' }, class: 'icon-btn delete', style: 'border: none; cursor: pointer; padding: 0;' %>
                    <% else %>
                      <%= link_to '◉', quote_path(quote), class: 'icon-btn view', style: 'text-decoration: none;' %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="add-area">
          <%= link_to new_quote_path, class: 'add-btn', style: 'text-decoration: none;' do %>
            <span class="plus">＋</span>
            Ajouter un devis
          <% end %>
        </div>
      <% else %>
        <div class="add-area">
          <%= link_to new_quote_path, class: 'add-btn', style: 'text-decoration: none;' do %>
            <span class="plus">＋</span>
            Ajouter un devis
          <% end %>
        </div>
      <% end %>
    </section>
  </div>
</div>
