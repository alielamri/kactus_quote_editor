<div class="min-h-screen bg-gray-100 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <div class="flex justify-between items-center mb-2">
        <h1 class="text-3xl font-bold text-gray-900">Mes devis</h1>
        <%= link_to 'Ajouter un devis', new_quote_path, class: 'px-4 py-2 bg-blue-600 text-white font-semibold rounded hover:bg-blue-700 transition' %>
      </div>
      <p class="text-gray-600 text-sm">Liste de tous vos devis</p>
    </div>

    <% if @quotes.any? %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Nom</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @quotes.each_with_index do |quote, index| %>
              <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
                <td class="px-6 py-4 text-sm text-gray-900 font-semibold">
                  <%= index + 1 %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-600">
                  <%= quote.created_at.strftime('%d/%m/%Y') %>
                </td>
                <td class="px-6 py-4 text-sm">
                  <%= link_to quote.name, quote_path(quote), class: 'text-blue-600 hover:text-blue-800 font-medium' %>
                </td>
                <td class="px-6 py-4 text-sm">
                  <span class="px-3 py-1 rounded-full text-xs font-semibold <%= quote.draft? ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800' %>">
                    <%= quote.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-right">
                  <div class="flex justify-end gap-3">
                    <% if quote.draft? %>
                      <%= link_to edit_quote_path(quote), class: 'inline-flex items-center justify-center w-8 h-8 rounded text-blue-600 hover:bg-blue-50 transition', title: 'Edit' do %>
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg>
                      <% end %>
                      <%= button_to quote_path(quote), method: :delete, data: { confirm: 'Êtes-vous sûr ?' }, class: 'inline-flex items-center justify-center w-8 h-8 rounded text-red-600 hover:bg-red-50 transition', title: 'Delete' do %>
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                      <% end %>
                    <% else %>
                      <button type="button" class="inline-flex items-center justify-center w-8 h-8 rounded text-gray-400 cursor-not-allowed" disabled title="Quote validé">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      </button>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <p class="text-gray-600 text-lg mb-4">Aucun devis pour le moment</p>
        <%= link_to 'Créer votre premier devis', new_quote_path, class: 'text-blue-600 hover:text-blue-800 font-semibold' %>
      </div>
    <% end %>
  </div>
</div>
